GATEWAY_APP_NAME=anotherme2-gateway
GATEWAY_ENV=dev
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080

# Postgres for production, sqlite for local quick start
GATEWAY_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/anotherme2

GATEWAY_REDIS_URL=redis://localhost:6379/0
GATEWAY_QUEUE_COURSE=q.course
GATEWAY_QUEUE_PROBLEM_VIDEO=q.problem_video
GATEWAY_QUEUE_PACKAGE=q.package
GATEWAY_QUEUE_LEARNING_RECORD=q.learning_record
GATEWAY_DLQ_PREFIX=q.dlq
GATEWAY_MAX_RETRIES=2
GATEWAY_RETRY_BASE_SECONDS=5
GATEWAY_RUNNING_JOB_STALE_SECONDS=2400
GATEWAY_RUNNING_JOB_RECOVER_BATCH=8
GATEWAY_RUNNING_JOB_RESULT_RECONCILE_BATCH=12
GATEWAY_MISSING_INPUT_CLEANUP_BATCH=12
GATEWAY_PURGE_PRESTART_JOBS_ON_STARTUP=0
GATEWAY_PURGE_PRESTART_JOBS_BATCH=5000
GATEWAY_PURGE_PRESTART_QUEUE_MESSAGES_ON_STARTUP=0
# Destructive startup purge is disabled unless explicitly armed.
# Set to 1 only for one-off maintenance.
GATEWAY_STARTUP_PURGE_ARMED=0

ANOTHERME_BASE_URL=http://localhost:3000
ANOTHERME_POLL_SECONDS=5
ANOTHERME_TIMEOUT_SECONDS=1200
GATEWAY_COURSE_GENERATION_PROVIDER=legacy

# local | s3 | minio
OBJECT_STORAGE_DRIVER=local
OBJECT_STORAGE_BUCKET=anotherme2-artifacts
OBJECT_STORAGE_ENDPOINT_URL=
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_PUBLIC_BASE_URL=
LOCAL_STORAGE_ROOT=./gateway_data/objects
GATEWAY_WORKER_TEMP_ROOT=./gateway_data/tmp
GATEWAY_WORKER_OUTPUT_ROOT=./gateway_data/runs
GATEWAY_KEEP_RUN_OUTPUT=1
ANOTHERME2_GENERATION_TIMEOUT_SEC=1800

# optional phase-1 auth token
GATEWAY_API_TOKEN=
